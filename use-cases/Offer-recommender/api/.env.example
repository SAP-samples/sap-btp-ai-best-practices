# Optional in local development. If unset, the API allows unauthenticated requests.
API_KEY='your-super-secret-api-key'

# Set for deployed environments so the UI origin is allowed by CORS.
ALLOWED_ORIGIN='http://127.0.0.1:5173'

# Set to 'production' in deployed environments.
APP_ENV='development'

AICORE_AUTH_URL=''
AICORE_CLIENT_ID=''
AICORE_CLIENT_SECRET=''
AICORE_BASE_URL=''
AICORE_RESOURCE_GROUP=''

# Required for the HANA-backed runtime and the seed-data loader script.
hana_address=''
hana_port=''
hana_user=''
hana_password=''
hana_encrypt='true'
