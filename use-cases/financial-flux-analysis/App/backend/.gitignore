# =============================================================================
# backend/.gitignore — Python / SAP HANA backend
# =============================================================================

# ── Credentials & Secrets ─────────────────────────────────────────────────────
# Real .env with HANA credentials and AI Core secrets — NEVER commit
.env
.env.*
!sample.env

# Cloud Foundry manifest with real credentials — use manifest.yaml.example as template
manifest.yaml
manifest.yml
*.local.bak

# ── Python bytecode ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
nosetests.xml

# ── Type checkers ─────────────────────────────────────────────────────────────
.mypy_cache/
.pyright/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
._*

# ── Editor ────────────────────────────────────────────────────────────────────
*.swp
*.swo