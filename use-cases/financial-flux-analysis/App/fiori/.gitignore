# =============================================================================
# fiori/.gitignore — SAP UI5 / Fiori frontend (Node.js + Vite)
# =============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.npm/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
build/
.cache/
.parcel-cache/

# ── Vite ──────────────────────────────────────────────────────────────────────
*.local
vite.config.*.timestamp-*

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
._*

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo